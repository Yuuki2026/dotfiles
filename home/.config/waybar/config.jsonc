{
    "layer": "top",
    "position": "top",

    "modules-left": [
        "custom/arch",
        "hyprland/workspaces"
    ],

    "modules-center": [
        "hyprland/window"
    ],

    "modules-right": [
        "cpu",
        "memory",
        "clock"
    ],

    "custom/arch": {
        "format": ""
    },

    "clock": {
        "format": "{:%Y-%m-%d %H:%M}"
    },

    "cpu": {
        "format": "CPU {usage}%"
    },

    "memory": {
        "format": "MEM {}%"
    }
}
